# Kopieer dit bestand naar .env en vul in:
#   cp .env.example .env
#   nano .env
#
# .env wordt door docker-compose.yml automatisch ingelezen (env_file)
# en NOOIT in git meegenomen (staat in .gitignore) -- hier staan
# straks je eigen wachtwoorden/tokens in.

APP_NAME=VacatureWatcher

# Verander dit in iets unieks/willekeurigs -- wordt gebruikt om
# sessies te ondertekenen. Bijvoorbeeld: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=verander_dit

# Pad BINNEN de container -- hoort bij het volume "./data:/app/data"
# in docker-compose.yml. Niet aanpassen tenzij je ook het volume
# aanpast.
DATABASE_PATH=/app/data/vacaturewatcher.db


# --- E-mail notificaties ---
EMAIL_ENABLED=false

SMTP_SERVER=
SMTP_PORT=587

SMTP_USERNAME=
SMTP_PASSWORD=

EMAIL_FROM=
EMAIL_TO=


# --- Telegram notificaties ---
# Bot aanmaken via https://core.telegram.org/bots
TELEGRAM_ENABLED=false

TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=


# --- CSO Vacature-API (Werken voor Nederland e.a.) ---
# Alleen nodig voor bronnen met adapter "cso_api".
# Account aanvragen via helpdesk@werkenvoornederland.nl
# zie adapters/EXAMPLES.md en adapters/cso_api.py voor details.
CSO_USERNAME=
CSO_PASSWORD=
